---
interface Props {
  title: string;
  description?: string;
  lang?: string;
  wide?: boolean;
}

const {
  title,
  description = 'Takahir-O - Products & Policies',
  lang = 'en',
  wide = false,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <title>{title}</title>
    <style is:global>
      :root {
        --color-bg: #09090b;
        --color-surface: #131316;
        --color-surface-hover: #1a1a1f;
        --color-border: #23232a;
        --color-text: #ececef;
        --color-text-secondary: #a0a0ab;
        --color-text-muted: #6b6b76;
        --color-accent: #34d399;
        --color-accent-hover: #6ee7b7;
        --gradient-primary: linear-gradient(135deg, #34d399 0%, #2dd4bf 100%);
        --gradient-bg: radial-gradient(
          ellipse 80% 50% at 50% -20%,
          rgba(52, 211, 153, 0.12),
          transparent
        );
        --max-width: 720px;
        --max-width-wide: 960px;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-family:
          'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          'Helvetica Neue', Arial, sans-serif;
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      a {
        color: var(--color-accent);
        text-decoration: none;
        transition: color 0.15s ease;
      }

      a:hover {
        color: var(--color-accent-hover);
      }

      /* Markdown content styles */
      .markdown-content h1 { font-size: 2rem; margin: 2rem 0 1rem; font-weight: 700; }
      .markdown-content h2 { font-size: 1.4rem; margin: 2.5rem 0 0.75rem; font-weight: 600; color: var(--color-text); }
      .markdown-content h3 { font-size: 1.15rem; margin: 2rem 0 0.5rem; font-weight: 600; }
      .markdown-content p { margin: 0.75rem 0; color: var(--color-text-secondary); }
      .markdown-content ul, .markdown-content ol { margin: 0.75rem 0; padding-left: 1.5rem; color: var(--color-text-secondary); }
      .markdown-content li { margin: 0.35rem 0; }
      .markdown-content strong { color: var(--color-text); font-weight: 600; }
      .markdown-content blockquote {
        border-left: 3px solid var(--color-accent);
        padding: 0.5rem 1rem;
        margin: 1rem 0;
        background: var(--color-surface);
        border-radius: 0 8px 8px 0;
      }
      .markdown-content blockquote p { color: var(--color-text-secondary); }
      .markdown-content code {
        background: var(--color-surface);
        padding: 0.15rem 0.4rem;
        border-radius: 4px;
        font-size: 0.9em;
      }
      .markdown-content hr {
        border: none;
        border-top: 1px solid var(--color-border);
        margin: 2rem 0;
      }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="nav-logo">Takahir-O</a>
        <div class="nav-links">
          <a href="/koekey/" class="nav-product">
            <img src="/images/koekey-logo.svg" alt="" width="20" height="20" class="nav-icon" />
            KoeKey
          </a>
        </div>
      </nav>
    </header>
    <main class:list={[{ wide }]}>
      <div class="markdown-content">
        <slot />
      </div>
    </main>
    <footer>
      <div class="footer-inner">
        <p>&copy; 2026 Takahir-O</p>
        <div class="footer-links">
          <a href="https://github.com/Takahir-O" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(9, 9, 11, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    padding: 0 1.5rem;
  }

  nav {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .nav-logo {
    color: var(--color-text);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: -0.01em;
  }

  .nav-logo:hover {
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .nav-links a {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-weight: 450;
  }

  .nav-links a:hover {
    color: var(--color-text);
  }

  .nav-product {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .nav-icon {
    border-radius: 4px;
  }

  main {
    flex: 1;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
    width: 100%;
  }

  main.wide {
    max-width: var(--max-width-wide);
  }

  footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 1.5rem;
  }

  .footer-inner {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .footer-links a:hover {
    color: var(--color-text);
  }
</style>
