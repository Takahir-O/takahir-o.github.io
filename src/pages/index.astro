---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Takahir-O" description="Products by Takahir-O">
  <h1>Products</h1>

  <section class="product-card">
    <h2>KoeKey</h2>
    <p>AI-powered voice dictation for Windows.</p>
    <a href="/koekey/" class="link">Learn more →</a>
  </section>
</BaseLayout>

<style>
  h1 {
    font-size: 2rem;
    margin-bottom: 2rem;
  }

  .product-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
  }

  .product-card h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .product-card p {
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .link {
    font-weight: 500;
  }
</style>
