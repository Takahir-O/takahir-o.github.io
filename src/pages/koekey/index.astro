---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="KoeKey - AI Voice Dictation" description="AI-powered voice dictation that keeps your data on your device" wide>
  <div class="glow"></div>

  <!-- Lang Switch -->
  <div class="lang-switch">
    <span class="lang-current">English</span>
    <a href="/koekey/ja/">日本語</a>
  </div>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-brand">
      <img src="/images/koekey-logo.svg" alt="" class="hero-logo" width="64" height="64" />
      <h1>KoeKey</h1>
    </div>
    <p class="hero-tagline">Your voice, your text.</p>
    <p class="hero-subtitle">
      AI-powered voice dictation for your PC.<br />
      Your data stays where it belongs — on your device.
    </p>
    <div class="hero-actions">
      <a
        href="https://apps.microsoft.com/detail/9NTW0S8D1GR4"
        class="btn-primary"
        target="_blank"
        rel="noopener noreferrer"
      >
        Get it on Microsoft Store
      </a>
    </div>
    <p class="hero-microcopy">Free to use — Windows 11 (macOS coming soon)</p>
  </section>

  <!-- Features -->
  <section class="features">
    <div class="section-header">
      <p class="section-label">Features</p>
      <h2>Everything you need for voice input.</h2>
    </div>
    <div class="feature-grid">
      <div class="feature-card">
        <div class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/><line x1="8" x2="16" y1="22" y2="22"/></svg>
        </div>
        <h3>Local Processing</h3>
        <p>
          On-device speech recognition with Whisper / sherpa-onnx.
          Works offline — your voice data never leaves your device.
        </p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>
        </div>
        <h3>Cloud STT</h3>
        <p>
          Choose from high-accuracy cloud AI engines like Soniox and Deepgram, using your own API key.
        </p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
        </div>
        <h3>Flexible Recording</h3>
        <p>
          Push-to-Talk mode records while holding a key or mouse button.
          Hands-free mode lets you dictate continuously without holding anything.
        </p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
        </div>
        <h3>Privacy First</h3>
        <p>
          Zero telemetry and analytics.
          Transcription history is encrypted with AES-256-GCM and stored locally.
        </p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="m9 14 2 2 4-4"/></svg>
        </div>
        <h3>Direct Input to Any App</h3>
        <p>
          Automatically pastes results into the active app.
          No copy-and-paste hassle — original clipboard contents are restored.
        </p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
        </div>
        <h3>Multilingual</h3>
        <p>
          UI available in English, Japanese, and Chinese.
          Speech recognition supports multiple languages depending on the model.
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="pricing">
    <div class="section-header">
      <p class="section-label">Pricing</p>
      <h2>Start for free. Upgrade once, use forever.</h2>
    </div>
    <div class="pricing-grid">
      <div class="pricing-card">
        <div class="pricing-tier">Free</div>
        <div class="pricing-price">$0</div>
        <p class="pricing-desc">Core voice dictation features, free forever.</p>
        <ul class="pricing-features">
          <li><span class="check">✓</span> Voice dictation (local &amp; cloud)</li>
          <li><span class="check">✓</span> Push-to-Talk &amp; Hands-free</li>
          <li><span class="check">✓</span> Direct input to any app</li>
          <li><span class="check">✓</span> Multilingual UI</li>
        </ul>
      </div>
      <div class="pricing-card pro">
        <div class="pricing-tier">Pro <span class="pricing-badge">One-time purchase</span></div>
        <div class="pricing-price">$21.49</div>
        <p class="pricing-desc">Unlock all features. No subscription, no recurring fees.</p>
        <ul class="pricing-features">
          <li><span class="check">✓</span> Everything in Free</li>
          <li><span class="check-pro">✓</span> Transcription history</li>
          <li><span class="check-pro">✓</span> Voice memo</li>
          <li><span class="check-pro">✓</span> Listening mode</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Privacy -->
  <section class="privacy-section">
    <div class="privacy-card">
      <p class="section-label">Privacy</p>
      <h2>Your voice stays on your device.</h2>
      <p class="privacy-description">
        With local models, all voice processing happens entirely on your device.
        Cloud providers are optional and only active when you explicitly configure them.
        KoeKey collects zero telemetry or analytics.
      </p>
      <div class="privacy-features">
        <div class="privacy-feature">
          <span class="check">✓</span>
          <span>Local voice processing</span>
        </div>
        <div class="privacy-feature">
          <span class="check">✓</span>
          <span>AES-256-GCM encryption</span>
        </div>
        <div class="privacy-feature">
          <span class="check">✓</span>
          <span>No telemetry</span>
        </div>
        <div class="privacy-feature">
          <span class="check">✓</span>
          <span>No external data storage</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Policy -->
  <section class="policies-section">
    <p class="section-label">Policy</p>
    <div class="policy-links">
      <a href="/koekey/privacy-policy" class="policy-link">
        <span class="policy-title">Privacy Policy</span>
        <span class="arrow">→</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .glow {
    position: fixed;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    height: 60%;
    background: radial-gradient(
      ellipse at center,
      rgba(52, 211, 153, 0.08) 0%,
      rgba(45, 212, 191, 0.03) 40%,
      transparent 70%
    );
    pointer-events: none;
    z-index: -1;
  }

  .lang-switch {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    padding: 0.5rem 0;
    font-size: 0.85rem;
  }
  .lang-current { color: var(--color-text); font-weight: 500; }
  .lang-switch a { color: var(--color-text-muted); }
  .lang-switch a:hover { color: var(--color-text); }

  /* Hero */
  .hero {
    text-align: center;
    padding: 4rem 0 3rem;
  }
  .hero-brand {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .hero-logo {
    border-radius: 14px;
    box-shadow: 0 4px 20px rgba(0, 132, 105, 0.25);
  }
  .hero-brand h1 {
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
  }
  .hero-tagline {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 600;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.75rem;
  }
  .hero-subtitle {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    max-width: 520px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }
  .hero-actions {
    display: flex;
    justify-content: center;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.8rem 1.75rem;
    background: var(--color-accent);
    color: #09090b;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.2s ease;
    box-shadow: 0 0 20px rgba(52, 211, 153, 0.2);
  }
  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: #09090b;
    transform: translateY(-1px);
    box-shadow: 0 0 30px rgba(52, 211, 153, 0.3);
  }
  .hero-microcopy {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 1.25rem;
  }

  /* Features */
  .features { padding: 3rem 0; }
  .section-header { margin-bottom: 2.5rem; }
  .section-label {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }
  .section-header h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 768px) { .feature-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .feature-grid { grid-template-columns: 1fr; } }
  .feature-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 1.75rem;
    transition: all 0.25s ease;
  }
  .feature-card:hover {
    border-color: rgba(52, 211, 153, 0.2);
    background: var(--color-surface-hover);
    transform: translateY(-2px);
  }
  .feature-icon { color: var(--color-accent); margin-bottom: 0.75rem; }
  .feature-card h3 { font-size: 1.05rem; font-weight: 600; margin-bottom: 0.5rem; }
  .feature-card p { color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6; }

  /* Pricing */
  .pricing { padding: 3rem 0; }
  .pricing-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media (max-width: 600px) { .pricing-grid { grid-template-columns: 1fr; } }
  .pricing-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 2rem;
  }
  .pricing-card.pro {
    border-color: rgba(52, 211, 153, 0.3);
    position: relative;
  }
  .pricing-card.pro::before {
    content: ''; position: absolute; inset: 0; border-radius: 16px;
    background: radial-gradient(ellipse at 50% 0%, rgba(52, 211, 153, 0.06), transparent 70%);
    pointer-events: none;
  }
  .pricing-tier {
    font-size: 1.1rem; font-weight: 700; margin-bottom: 0.5rem;
    display: flex; align-items: center; gap: 0.75rem;
  }
  .pricing-badge {
    font-size: 0.7rem; font-weight: 500; padding: 0.2rem 0.6rem;
    background: rgba(52, 211, 153, 0.1); color: var(--color-accent);
    border-radius: 100px; border: 1px solid rgba(52, 211, 153, 0.2);
  }
  .pricing-price { font-size: 1.75rem; font-weight: 800; margin-bottom: 0.5rem; letter-spacing: -0.02em; }
  .pricing-desc { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 1.5rem; }
  .pricing-features { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
  .pricing-features li { display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; color: var(--color-text-secondary); }
  .check { color: var(--color-accent); font-weight: 600; }
  .check-pro { color: var(--color-accent); font-weight: 600; }

  /* Privacy */
  .privacy-section { padding: 3rem 0; }
  .privacy-card {
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: 16px; padding: 3rem; text-align: center;
    position: relative; overflow: hidden;
  }
  .privacy-card::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(52, 211, 153, 0.05), transparent 70%);
    pointer-events: none;
  }
  .privacy-card h2 { font-size: clamp(1.3rem, 3vw, 1.75rem); font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1rem; position: relative; }
  .privacy-card .section-label { position: relative; }
  .privacy-description { color: var(--color-text-secondary); max-width: 560px; margin: 0 auto 2rem; font-size: 0.95rem; position: relative; }
  .privacy-features { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; position: relative; }
  .privacy-feature {
    display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem;
    color: var(--color-text-secondary); padding: 0.4rem 1rem;
    background: rgba(52, 211, 153, 0.06); border-radius: 100px; border: 1px solid rgba(52, 211, 153, 0.1);
  }

  /* Policies */
  .policies-section { padding: 3rem 0 1rem; }
  .policy-links { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 1rem; }
  .policy-link {
    display: flex; align-items: center; gap: 1rem; padding: 1.25rem 1.5rem;
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: 12px; color: inherit; transition: all 0.2s ease;
  }
  .policy-link:hover { border-color: rgba(52, 211, 153, 0.2); background: var(--color-surface-hover); color: inherit; }
  .policy-title { font-weight: 500; font-size: 0.95rem; }
  .arrow { margin-left: auto; color: var(--color-text-muted); transition: all 0.2s ease; }
  .policy-link:hover .arrow { color: var(--color-accent); transform: translateX(3px); }
</style>
