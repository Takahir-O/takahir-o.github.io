---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="KoeKey - Voice Dictation for Windows" description="AI-powered voice dictation that keeps your data on your device" wide>
  <div class="glow"></div>

  <!-- Lang Switch -->
  <div class="lang-switch">
    <span class="lang-current">English</span>
    <a href="/koekey/ja/">日本語</a>
  </div>

  <!-- Hero -->
  <section class="hero">
    <img src="/images/koekey-logo.svg" alt="KoeKey" class="hero-logo" width="80" height="80" />
    <span class="hero-badge">Voice Dictation for Windows</span>
    <h1>
      <span class="gradient-text">Your voice, your text.</span>
    </h1>
    <p class="hero-subtitle">
      AI-powered voice dictation that keeps your data where it belongs — on your device.
    </p>
    <div class="hero-actions">
      <a
        href="https://apps.microsoft.com/detail/9NTW0S8D1GR4"
        class="btn-primary"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="20" height="20" viewBox="0 0 23 23" fill="none" aria-hidden="true">
          <rect x="1" y="1" width="10" height="10" fill="currentColor" />
          <rect x="12" y="1" width="10" height="10" fill="currentColor" />
          <rect x="1" y="12" width="10" height="10" fill="currentColor" />
          <rect x="12" y="12" width="10" height="10" fill="currentColor" />
        </svg>
        Get it on Microsoft Store
      </a>
    </div>
  </section>

  <!-- Features -->
  <section class="features">
    <div class="section-header">
      <p class="section-label">Features</p>
      <h2>Everything you need for voice input.</h2>
    </div>
    <div class="feature-grid">
      <div class="feature-card">
        <div class="feature-icon">🎤</div>
        <h3>Local Processing</h3>
        <p>
          On-device speech recognition with Whisper / sherpa-onnx.
          Works offline — your voice data never leaves your device.
        </p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">☁️</div>
        <h3>Cloud STT</h3>
        <p>
          Supports Soniox and Deepgram. Use your own API key for high-accuracy cloud speech recognition.
        </p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🎯</div>
        <h3>Push-to-Talk</h3>
        <p>
          Record only while holding a key. Works with touch, mouse, and keyboard.
          Hands-free mode also available.
        </p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🔒</div>
        <h3>Privacy First</h3>
        <p>
          Zero telemetry and analytics.
          Transcription history is encrypted with AES-256-GCM and stored locally.
        </p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📋</div>
        <h3>Smart Clipboard</h3>
        <p>
          Automatically pastes results into the active app.
          Original clipboard contents are restored afterward.
        </p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🌐</div>
        <h3>Multilingual</h3>
        <p>
          UI available in English, Japanese, and Chinese.
          Speech recognition supports multiple languages depending on the model.
        </p>
      </div>
    </div>
  </section>

  <!-- Privacy -->
  <section class="privacy-section">
    <div class="privacy-card">
      <p class="section-label">Privacy</p>
      <h2>Your voice stays on your device.</h2>
      <p class="privacy-description">
        With local models, all voice processing happens entirely on your device.
        Cloud providers are optional and only active when you explicitly configure them.
        KoeKey collects zero telemetry or analytics.
      </p>
      <div class="privacy-features">
        <div class="privacy-feature">
          <span class="check">✓</span>
          <span>Local voice processing</span>
        </div>
        <div class="privacy-feature">
          <span class="check">✓</span>
          <span>AES-256-GCM encryption</span>
        </div>
        <div class="privacy-feature">
          <span class="check">✓</span>
          <span>No telemetry</span>
        </div>
        <div class="privacy-feature">
          <span class="check">✓</span>
          <span>No external data storage</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Policy -->
  <section class="policies-section">
    <p class="section-label">Policy</p>
    <div class="policy-links">
      <a href="/koekey/privacy-policy" class="policy-link">
        <span class="policy-title">Privacy Policy</span>
        <span class="arrow">→</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .glow {
    position: fixed;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    height: 60%;
    background: radial-gradient(
      ellipse at center,
      rgba(129, 140, 248, 0.1) 0%,
      rgba(192, 132, 252, 0.04) 40%,
      transparent 70%
    );
    pointer-events: none;
    z-index: -1;
  }

  /* Lang Switch */
  .lang-switch {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    padding: 0.5rem 0;
    font-size: 0.85rem;
  }

  .lang-current {
    color: var(--color-text);
    font-weight: 500;
  }

  .lang-switch a {
    color: var(--color-text-muted);
  }

  .lang-switch a:hover {
    color: var(--color-text);
  }

  /* Hero */
  .hero-logo {
    border-radius: 18px;
    margin-bottom: 1.5rem;
    box-shadow: 0 4px 24px rgba(0, 132, 105, 0.2);
  }

  .hero {
    text-align: center;
    padding: 4rem 0 4rem;
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.35rem 1rem;
    background: rgba(129, 140, 248, 0.1);
    color: var(--color-accent);
    border-radius: 100px;
    border: 1px solid rgba(129, 140, 248, 0.2);
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 7vw, 4rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.04em;
    margin-bottom: 1.25rem;
  }

  .gradient-text {
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: var(--color-text-secondary);
    max-width: 520px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.8rem 1.75rem;
    background: var(--color-accent);
    color: #fff;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.2s ease;
    box-shadow: 0 0 20px rgba(129, 140, 248, 0.25);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 0 30px rgba(129, 140, 248, 0.35);
  }

  /* Features */
  .features {
    padding: 3rem 0;
  }

  .section-header {
    margin-bottom: 2.5rem;
  }

  .section-label {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .section-header h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  @media (max-width: 768px) {
    .feature-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .feature-grid {
      grid-template-columns: 1fr;
    }
  }

  .feature-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 1.75rem;
    transition: all 0.25s ease;
  }

  .feature-card:hover {
    border-color: rgba(129, 140, 248, 0.2);
    background: var(--color-surface-hover);
    transform: translateY(-2px);
  }

  .feature-icon {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .feature-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .feature-card p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  /* Privacy */
  .privacy-section {
    padding: 3rem 0;
  }

  .privacy-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 3rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .privacy-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 50% 0%,
      rgba(129, 140, 248, 0.06),
      transparent 70%
    );
    pointer-events: none;
  }

  .privacy-card h2 {
    font-size: clamp(1.3rem, 3vw, 1.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    position: relative;
  }

  .privacy-card .section-label {
    position: relative;
  }

  .privacy-description {
    color: var(--color-text-secondary);
    max-width: 560px;
    margin: 0 auto 2rem;
    font-size: 0.95rem;
    position: relative;
  }

  .privacy-features {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    position: relative;
  }

  .privacy-feature {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    padding: 0.4rem 1rem;
    background: rgba(129, 140, 248, 0.06);
    border-radius: 100px;
    border: 1px solid rgba(129, 140, 248, 0.1);
  }

  .check {
    color: var(--color-accent);
    font-weight: 600;
  }

  /* Policies */
  .policies-section {
    padding: 3rem 0 1rem;
  }

  .policy-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .policy-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    color: inherit;
    transition: all 0.2s ease;
  }

  .policy-link:hover {
    border-color: rgba(129, 140, 248, 0.2);
    background: var(--color-surface-hover);
    color: inherit;
  }

  .policy-title {
    font-weight: 500;
    font-size: 0.95rem;
  }

  .arrow {
    margin-left: auto;
    color: var(--color-text-muted);
    transition: all 0.2s ease;
  }

  .policy-link:hover .arrow {
    color: var(--color-accent);
    transform: translateX(3px);
  }
</style>
